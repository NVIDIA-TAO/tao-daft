{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://developer.nvidia.com/tao-daft/schemas/metropolis-v3.0/open_qa.schema.json",
  "title": "Video Open-Ended QA Task Annotation",
  "description": "Open-ended question answering task for videos. Each item pairs a natural-language question with a free-form answer for the video identified by video_id.",
  "type": "object",
  "required": [
    "version",
    "metadata",
    "items"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "metropolis-v3.0",
      "description": "Schema version - must be '3.0' for this schema"
    },
    "items": {
      "type": "array",
      "description": "Array of open-ended QA items, one per question-answer pair",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "question",
          "answer"
        ],
        "additionalProperties": false,
        "properties": {
          "video_id": {
            "type": "string",
            "description": "Reference to video ID (matches directory name in contextual/)"
          },
          "question": {
            "type": "string",
            "description": "Natural-language question about the video content"
          },
          "answer": {
            "type": "string",
            "description": "Free-form answer to the question"
          },
          "reasoning": {
            "type": "string",
            "description": "Optional step-by-step reasoning trace leading to the answer"
          },
          "image_id": {
            "type": "string",
            "description": "Reference to image_id in image_*.json",
            "minLength": 1
          }
        },
        "oneOf": [
          {
            "required": [
              "video_id"
            ]
          },
          {
            "required": [
              "image_id"
            ]
          }
        ]
      }
    },
    "metadata": {
      "type": "object",
      "description": "File metadata for identification and cataloging",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "description": "Task type identifier (must be 'open_qa')",
          "const": "open_qa"
        },
        "date": {
          "type": "string",
          "description": "Creation date in ISO 8601 format (YYYY-MM-DD)",
          "format": "date"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this annotation file"
        },
        "license": {
          "type": "string",
          "description": "License under which this annotation is distributed"
        },
        "tags": {
          "type": "array",
          "description": "List of tags for categorization and search",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
