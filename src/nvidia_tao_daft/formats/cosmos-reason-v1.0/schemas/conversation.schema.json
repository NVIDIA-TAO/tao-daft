{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://developer.nvidia.com/tao-daft/schemas/cosmos-reason-v1.0/conversation.schema.json",
  "title": "Cosmos Reason Conversation",
  "description": "Single training sample conversation for Cosmos Reason v1.0. Contains alternating user/assistant turns with optional system preamble. Media references use positional placeholders (image_0, video_0) resolved via meta.json.",
  "type": "object",
  "required": [
    "version",
    "metadata",
    "conversations"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "cosmos-reason-v1.0",
      "description": "Format version - must be 'cosmos-reason-v1.0' for this schema"
    },
    "metadata": {
      "type": "object",
      "description": "File metadata for identification and cataloging",
      "required": [
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "conversation",
          "description": "File type identifier (must be 'conversation')"
        },
        "date": {
          "type": "string",
          "description": "Creation date in ISO 8601 format (YYYY-MM-DD)",
          "format": "date"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this conversation sample"
        },
        "license": {
          "type": "string",
          "description": "License under which this annotation is distributed"
        },
        "tags": {
          "type": "array",
          "description": "List of tags for categorization and search",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "conversations": {
      "type": "array",
      "description": "Ordered list of conversation turns. Must start with 'user' (optionally preceded by one 'system' turn) and alternate user/assistant.",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "additionalProperties": false,
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "system",
              "user",
              "assistant"
            ],
            "description": "Role of the message author"
          },
          "reasoning_content": {
            "type": "array",
            "description": "Optional chain-of-thought reasoning trace. Present only on assistant turns. Each item is a text block containing the model's internal reasoning before producing the final answer.",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "type",
                "text"
              ],
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": "string",
                  "const": "text"
                },
                "text": {
                  "type": "string",
                  "description": "Reasoning trace text",
                  "minLength": 1
                }
              }
            }
          },
          "content": {
            "type": "array",
            "description": "List of content items for this turn",
            "minItems": 1,
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "description": "Text content item",
                  "required": [
                    "type",
                    "text"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "text"
                    },
                    "text": {
                      "type": "string",
                      "description": "Text content",
                      "minLength": 1
                    }
                  }
                },
                {
                  "type": "object",
                  "description": "Image content item. The 'image' field is a positional placeholder (e.g. 'image_0') resolved to the actual file via meta.json.",
                  "required": [
                    "type",
                    "image"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "image"
                    },
                    "image": {
                      "type": "string",
                      "description": "Positional placeholder for the image (e.g. 'image_0')",
                      "pattern": "^image_[0-9]+$"
                    }
                  }
                },
                {
                  "type": "object",
                  "description": "Video content item. The 'video' field is a positional placeholder (e.g. 'video_0') resolved to the actual file via meta.json.",
                  "required": [
                    "type",
                    "video"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "video"
                    },
                    "video": {
                      "type": "string",
                      "description": "Positional placeholder for the video (e.g. 'video_0')",
                      "pattern": "^video_[0-9]+$"
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
